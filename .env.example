# Lokální měřicí běh potřebuje jen DATABASE_URL.
DATABASE_URL=postgres://casomira:casomira@localhost:5432/casomira

# Auth (org login). Vygeneruj: openssl rand -base64 32
AUTH_SECRET=
APP_BASE_URL=http://localhost:3000

# Jednosměrný sync na cloud (volitelné, mimo kritickou cestu měření).
# Na LOKÁLNÍ instanci: kam publikovat výsledky.
CLOUD_SYNC_URL=
# Na CLOUD instanci: sdílený token, kterým se push autorizuje.
SYNC_TOKEN=
